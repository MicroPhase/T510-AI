CONFIG_USE_BOOTCOMMAND=y
CONFIG_DEFAULT_DEVICE_TREE="zynqmp-t510-ai"
CONFIG_DEBUG_UART_BASE=0xff010000
CONFIG_DEBUG_UART_CLOCK=100000000
CONFIG_CMD_BOOTI=y
CONFIG_CMD_FPGA=y
CONFIG_BOOTDELAY=1
CONFIG_BOOTCOMMAND="setenv bitstream_image t510_ai_100g_full_system_top.bit; setenv bitstream_load_address 0x30000000; setenv kernel_image Image; setenv devicetree_image devicetree.dtb; setenv ramdisk_image uramdisk.image.gz; setenv kernel_load_address 0x02000000; setenv ramdisk_load_address 0x04000000; setenv devicetree_load_address 0x10000000; if mmc dev 0; then if fatload mmc 0:1 0x10000000 uEnv.txt; then env import -t 0x10000000 ${filesize}; fi; if env exists uenvcmd; then run uenvcmd; fi; echo Loading FPGA bitstream from SD...; if fatload mmc 0:1 ${bitstream_load_address} ${bitstream_image}; then if fpga loadb 0 ${bitstream_load_address} ${filesize}; then if fatload mmc 0:1 ${kernel_load_address} ${kernel_image}; then if fatload mmc 0:1 ${ramdisk_load_address} ${ramdisk_image}; then setenv ramdisk_size ${filesize}; if fatload mmc 0:1 ${devicetree_load_address} ${devicetree_image}; then booti ${kernel_load_address} ${ramdisk_load_address}:${ramdisk_size} ${devicetree_load_address}; fi; fi; fi; fi; fi; fi; sf probe 0 0 0; sf read 0x10000000 0x400000 0x2000000; bootm 0x10000000"
CONFIG_PARTITIONS=y
CONFIG_DOS_PARTITION=y
CONFIG_CMD_FAT=y
CONFIG_CMD_FS_GENERIC=y
# CONFIG_ENV_IS_IN_FAT is not set
CONFIG_ENV_IS_NOWHERE=y
