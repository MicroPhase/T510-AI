#!/bin/sh

DAEMON="/usr/sbin/t510-fnic-rfdc"
PIDFILE="/var/run/t510-fnic-rfdc.pid"
LOGFILE="${T510_FNIC_RFDC_LOG:-/var/log/t510-fnic-rfdc.log}"
ARGS="${T510_FNIC_RFDC_ARGS:---no-dump}"

start() {
	if [ ! -x "$DAEMON" ]; then
		echo "missing $DAEMON"
		return 1
	fi

	case " $ARGS " in
		*" --server "*)
			if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
				echo "t510-fnic-rfdc already running"
				return 0
			fi

			echo "Starting t510-fnic-rfdc server..."
			mkdir -p "$(dirname "$PIDFILE")" "$(dirname "$LOGFILE")"
			start-stop-daemon -S -b -m -p "$PIDFILE" -x "$DAEMON" -- \
				$ARGS >>"$LOGFILE" 2>&1
			return $?
			;;
	esac

	echo "Running one-shot t510-fnic-rfdc initialization..."
	mkdir -p "$(dirname "$LOGFILE")"
	"$DAEMON" $ARGS >>"$LOGFILE" 2>&1
	return $?
}

stop() {
	if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
		echo "Stopping t510-fnic-rfdc..."
		start-stop-daemon -K -p "$PIDFILE" -x "$DAEMON" 2>/dev/null || true
		rm -f "$PIDFILE"
		return 0
	fi
	echo "t510-fnic-rfdc is not running as a server"
}

case "$1" in
	start)
		start
		;;
	stop)
		stop
		;;
	restart|reload)
		stop
		start
		;;
	status)
		if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null; then
			echo "t510-fnic-rfdc running"
			exit 0
		fi
		echo "t510-fnic-rfdc stopped"
		exit 1
		;;
	*)
		echo "Usage: $0 {start|stop|restart|status}"
		exit 1
		;;
esac

exit 0
