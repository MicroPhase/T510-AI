# Generated by export_current_project_scripts.tcl from the current Vivado project.
# Do not edit this file by hand; open the Vivado project, update filesets, then rerun:
#   hdl/t510_fnic/scripts/export_current_project_scripts.sh --apply

if {![info exists root_dir]} {
  set script_dir [file normalize [file dirname [info script]]]
  set root_dir   [file normalize [file join $script_dir ".." ".."]]
}

proc t510_add_rel_files {fileset root_dir relpaths args} {
  if {[llength $relpaths] == 0} {
    return
  }
  set files [list]
  foreach rel $relpaths {
    lappend files [file join $root_dir $rel]
  }
  add_files -fileset $fileset {*}$args $files
}

proc t510_import_rel_ip_files {root_dir relpaths} {
  if {[llength $relpaths] == 0} {
    return
  }
  set files [list]
  foreach rel $relpaths {
    lappend files [file join $root_dir $rel]
  }
  import_files -fileset sources_1 $files
}

set t510_source_rel_files [list \
  "top/t510_fnic/rtl/axi_peek_poke_v1_0_S00_AXI.v" \
  "top/t510_fnic/rtl/t510_fnic_aurora_bringup_top.v" \
